{
  "name": "@meer-ai/tui",
  "version": "0.6.45",
  "description": "Differential-rendering terminal UI for meer (vendored from pi-tui, MIT).",
  "type": "module",
  "license": "MIT",
  "exports": {
    "./*.js": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "native/win32/prebuilds/**/*.node",
    "native/darwin/prebuilds/**/*.node",
    "LICENSE.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "get-east-asian-width": "1.6.0",
    "marked": "^15.0.12"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/meer-ai/meer.git",
    "directory": "packages/tui"
  }
}
