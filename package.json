{
  "name": "meerai",
  "version": "0.6.39",
  "description": "MeerAI - Dive deep into your code. An open-source, local-first AI CLI for developers.",
  "type": "module",
  "packageManager": "pnpm@9.12.3",
  "bin": {
    "meer": "./bin/meer.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/meer-ai/meer.git"
  },
  "bugs": {
    "url": "https://github.com/meer-ai/meer/issues"
  },
  "homepage": "https://github.com/meer-ai/meer#readme",
  "scripts": {
    "build": "pnpm -C packages/core run build && pnpm -C packages/ai run build && pnpm -C packages/agent run build && pnpm -C packages/tui run build && pnpm -C packages/coding-agent run build",
    "dev": "tsx packages/coding-agent/src/index.ts",
    "check": "tsc -p tsconfig.json --noEmit",
    "preflight": "pnpm run build && pnpm run check && pnpm test",
    "prepublishOnly": "pnpm run preflight",
    "test": "node scripts/run-verifications.mjs",
    "set-version": "node scripts/set-version.mjs",
    "publish-all": "node scripts/publish.mjs",
    "release": "./scripts/release.sh"
  },
  "keywords": [
    "cli",
    "ai",
    "developer",
    "meerai",
    "ollama",
    "openai",
    "gemini",
    "anthropic",
    "huggingface",
    "llm",
    "assistant",
    "local-first",
    "privacy"
  ],
  "author": "MeerAI Contributors",
  "license": "MIT",
  "dependencies": {
    "@meer-ai/coding-agent": "workspace:*"
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/diff": "^7.0.2",
    "@types/node": "^20.0.0",
    "strip-ansi": "^6.0.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "yaml": "^2.9.0"
  },
  "pnpm": {
    "overrides": {
      "minimatch@>=5.0.0 <5.1.8": "5.1.8",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
      "path-to-regexp@>=8.0.0 <8.4.0": "8.4.0",
      "qs@<6.15.2": "6.15.2",
      "esbuild@>=0.17.0 <0.28.1": "0.28.1"
    },
    "supportedArchitectures": {
      "os": ["win32", "linux"],
      "cpu": ["x64"]
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "bin",
    "README.md",
    "LICENSE"
  ]
}
